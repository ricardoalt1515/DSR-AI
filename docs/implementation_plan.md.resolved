### Fix G3 — Reuse EditItemDrawer for voice

#### [MODIFY] [voice-review-workspace.tsx](file:///Users/ricardoaltamirano/Developer/waste-platform/frontend/components/features/voice-interview/voice-review-workspace.tsx)

```diff
+import { EditItemDrawer } from "../bulk-import/edit-item-drawer";
+const [editingItem, setEditingItem] = useState<BulkImportItem | null>(null);
 // In StreamCard: replace inline edit with:
+onEdit={() => setEditingItem(item)}
 // At bottom of JSX:
+<EditItemDrawer
+  item={editingItem}
+  open={!!editingItem}
+  onOpenChange={(open) => { if (!open) setEditingItem(null); }}
+  onSaved={(updated) => {
+    setItems(prev => prev.map(i => i.id === updated.id ? updated : i));
+    setEditingItem(null);
+  }}
+/>
```

